DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Auth (Better Auth)
BETTER_AUTH_SECRET=""  # mind. 32 Zeichen, zufällig generiert (z.B. openssl rand -base64 32)
