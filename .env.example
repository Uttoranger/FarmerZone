# ─── Datenbank (Supabase PostgreSQL) ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Authentifizierung (Better Auth) ─────────────────────────────────────────
BETTER_AUTH_SECRET=""        # mind. 32 Zeichen, generieren: openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"   # in Prod: https://deine-domain.at

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."           # in Prod: sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."  # in Prod: pk_live_...
STRIPE_WEBHOOK_SECRET="whsec_..."        # aus: stripe listen --print-secret
STRIPE_CONNECT_CLIENT_ID="ca_..."        # Stripe Dashboard → Connect Settings

# ─── E-Mail (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="bestellung@deine-domain.at"  # muss verifizierte Resend-Domain sein

# ─── File Upload (Vercel Blob) ────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."  # Vercel Dashboard → Storage → Blob

# ─── App-Konfiguration ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"  # in Prod: https://deine-domain.at

# ─── Cron-Job Absicherung ─────────────────────────────────────────────────────
CRON_SECRET=""   # zufälliger String, z.B. openssl rand -hex 16

# ─── Optional: Sentry Error Tracking ─────────────────────────────────────────
# SENTRY_DSN=""
